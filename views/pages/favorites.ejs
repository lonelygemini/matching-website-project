<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Favourites</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body class="favorites-page">
  <header>
    <%- include('../partials/header') %>
  </header>
  <main>
    <h1>Jouw favoriete vacatures</h1>

    <section class="profiel">
      <aside>
        <nav>
          <a href="/profiel">Mijn Profiel</a>
          <a href="/favorites" class="active">Favorieten</a>
        </nav>
      </aside>

      <div class="favorites-right">
        <div class="favorites-top">
          <p>
            Hier vind je alle jobs die je hebt opgeslagen. Bekijk ze op elk gewenst moment en ga verder met je aanvraagprocedure.
          </p>

          <a href="/filter" class="favorites-top-button">Zoek meer jobs</a>
          
        </div>

  <% if (jobs && jobs.length > 0) { %>
    <div class="favorite-jobs-list">
      <% jobs.forEach(job => { %>
        <%- include('../partials/bookmark-card', { job: job }) %>
      <% }) %>
    </div>
  <% } else { %>
    <div class="favorites-empty">
      <h2>Ben je nog op zoek naar een baan?</h2>
    </div>
  <% } %>
</div>

      </div>
    </section>
  </main>
</body>
<footer>
  <%- include('../partials/footer') %>
</footer>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Job-cards</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
  <main>
    <% data.forEach(job => { %>
      <section class="jobCard">
        <div class="card-header">
          <div>
            <h1><%= job.title %></h1>
            <h2><%= job.company %></h2>
          </div>

          <div class="extra">
            <p><%= job.locations %></p>
            <p><%- job.salary %></p> </div>
          </div>

          <div class="tekst">
            <p><%= job.description %></p>
          </div>
        <a href="/detail/<%-job._id %>"> View details</a>
        <a href="#"> Favoriet</a>
        
      </section>

    <% }) %>
  </main>


</body>
</html>

